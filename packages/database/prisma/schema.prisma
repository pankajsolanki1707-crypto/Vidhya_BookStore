datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String?
  phone         String?
  walletBalance Float    @default(150.0)
  rewardPoints  Int      @default(340)
  orders        Order[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Product {
  id            String      @id
  title         String
  author        String
  publisher     String?
  price         Float
  originalPrice Float?
  category      String
  subcategory   String?
  format        String
  image         String
  description   String
  stockCount    Int         @default(10)
  inStock       Boolean     @default(true)
  isbn          String?
  pages         Int?
  publishYear   Int?
  featured      Boolean     @default(false)
  isBestseller  Boolean     @default(false)
  isNewArrival  Boolean     @default(false)
  board         String?
  exam          String?
  branch        String?
  orderItems    OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Order {
  id               String      @id
  userId           String?
  user             User?       @relation(fields: [userId], references: [id])
  customerName     String
  phone            String
  telegram         String?
  address          String
  city             String
  state            String
  pincode          String
  totalAmount      Float
  paymentMethod    String
  paymentReference String?
  status           String      @default("Pending")
  items            OrderItem[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
}

model AuditLog {
  id        String   @id @default(uuid())
  timestamp DateTime @default(now())
  ip        String
  user      String
  action    String
}
